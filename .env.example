# HTTP Proxy Catcher - Environment Variables Example
# Copy this file to .env and customize as needed

# Server Configuration
# PORT=5173
# HOST=localhost

# Development
# NODE_ENV=development

# CORS Configuration (if needed)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Security (for production deployments)
# SESSION_SECRET=your-secret-key-here
# API_KEY=your-api-key-here

# Rate Limiting (if implemented)
# RATE_LIMIT_WINDOW=60000
# RATE_LIMIT_MAX_REQUESTS=100

# Logging
# LOG_LEVEL=info
# LOG_FORMAT=json

# Database (if adding persistence)
# DATABASE_URL=postgresql://user:password@localhost:5432/http_catcher
# REDIS_URL=redis://localhost:6379

# Default Configuration
# DEFAULT_TARGET_HOST=https://api.example.com
# MAX_BODY_SIZE=1048576

# Feature Flags
# ENABLE_AUTH=false
# ENABLE_PERSISTENCE=false
# ENABLE_RATE_LIMITING=false

# Note: Currently, the application doesn't use environment variables.
# This file is provided as a template for future enhancements.
